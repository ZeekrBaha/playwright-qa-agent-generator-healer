# Required
OPENAI_API_KEY=sk-...

# Optional model overrides (default: gpt-4o-mini for all stages)
# OPENAI_MODEL_PLANNER=gpt-4o-mini
# OPENAI_MODEL_EXPLORER=gpt-4o-mini
# OPENAI_MODEL_CRITIC=gpt-4o-mini
# OPENAI_MODEL_HEAL=gpt-4o-mini

# Hard ceilings
# VERIPLAY_MAX_STEPS=40
# VERIPLAY_MAX_USD=2.00

# E2E tests (disabled by default)
# RUN_E2E=1
